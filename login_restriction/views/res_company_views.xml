<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_inherit_login_restriction" model="ir.ui.view">
        <field name="name">res.company.form.inherit.login.restriction</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Login Control" groups="base.group_system">
                    <group>
                        <group string="Working Hours Range">
                            <label for="restrict_login_start_hour" string="Start Hour"/>
                            <div class="o_row">
                                <field name="restrict_login_start_hour" widget="float_time" class="oe_inline"/>
                            </div>
                            <label for="restrict_login_end_hour" string="End Hour"/>
                            <div class="o_row">
                                <field name="restrict_login_end_hour" widget="float_time" class="oe_inline"/>
                            </div>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
