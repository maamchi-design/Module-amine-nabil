<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_inherit_login_restriction" model="ir.ui.view">
        <field name="name">res.users.form.inherit.login.restriction</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Login Restriction" name="login_restriction" groups="base.group_system">
                    <group>
                        <field name="has_login_restriction"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
