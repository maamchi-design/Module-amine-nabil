<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_inherit_login_restriction" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.login.restriction</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='hr_settings']//group" position="inside">
                <group string="Login Control" groups="base.group_system,hr.group_hr_user">
                    <field name="has_login_restriction"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
